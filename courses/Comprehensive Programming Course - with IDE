## 8.5 Project Step: Build the 3D Game Board

We'll create a board with 4 quadrants, each with 5 squares (total 20 squares).

### Create `GameBoard3D` class

```java
package knowledgequestfx;

import javafx.scene.Group;
import javafx.scene.shape.Box;
import javafx.scene.paint.PhongMaterial;
import javafx.scene.paint.Color;

public class GameBoard3D {
    private Group boardGroup;
    private Box[][] squares;  // 4 rows x 5 columns

    public GameBoard3D() {
        boardGroup = new Group();
        squares = new Box[4][5];
        buildBoard();
    }

    private void buildBoard() {
        double squareSize = 150;
        double gap = 10;
        double startX = - (4 * (squareSize + gap)) / 2;
        double startZ = - (5 * (squareSize + gap)) / 2;

        for (int row = 0; row < 4; row++) {
            for (int col = 0; col < 5; col++) {
                Box square = new Box(squareSize, 5, squareSize);
                square.setTranslateX(startX + row * (squareSize + gap));
                square.setTranslateZ(startZ + col * (squareSize + gap));
                square.setTranslateY(0);

                // Color based on row
                Color color = Color.rgb(100 + row * 40, 100, 200 - row * 30);
                PhongMaterial material = new PhongMaterial(color);
                square.setMaterial(material);

                squares[row][col] = square;
                boardGroup.getChildren().add(square);
            }
        }
    }

    public Group getGroup() {
        return boardGroup;
    }

    public Box getSquare(int row, int col) {
        return squares[row][col];
    }
}
```

