### Module 1: Project Setup and Basic Ship Movement

**Learn**: Java basics, variables, loops, input handling

**Build**: A simple window with a spaceship you can move with WASD or arrow keys.

**Online Tool**: Replit (JavaFX template)

**Code Skeleton**:

```java
import javafx.application.Application;
import javafx.scene.Scene;
import javafx.scene.canvas.Canvas;
import javafx.scene.canvas.GraphicsContext;
import javafx.scene.input.KeyCode;
import javafx.scene.layout.Pane;
import javafx.scene.paint.Color;
import javafx.stage.Stage;

public class StarWanderer extends Application {
    private double shipX = 400, shipY = 300;
    private double shipSpeed = 3;

    @Override
    public void start(Stage primaryStage) {
        Canvas canvas = new Canvas(800, 600);
        GraphicsContext gc = canvas.getGraphicsContext2D();

        Pane root = new Pane();
        root.getChildren().add(canvas);

        Scene scene = new Scene(root, 800, 600);
        scene.setOnKeyPressed(e -> {
            KeyCode key = e.getCode();
            if (key == KeyCode.W || key == KeyCode.UP) shipY -= shipSpeed;
            if (key == KeyCode.S || key == KeyCode.DOWN) shipY += shipSpeed;
            if (key == KeyCode.A || key == KeyCode.LEFT) shipX -= shipSpeed;
            if (key == KeyCode.D || key == KeyCode.RIGHT) shipX += shipSpeed;
            drawShip(gc);
        });

        primaryStage.setTitle("Star Wanderer");
        primaryStage.setScene(scene);
        primaryStage.show();
        drawShip(gc);
    }

    private void drawShip(GraphicsContext gc) {
        gc.setFill(Color.BLACK);
        gc.fillRect(0, 0, 800, 600);
        gc.setFill(Color.WHITE);
        gc.fillPolygon(
            new double[]{shipX, shipX - 15, shipX + 15},
            new double[]{shipY - 20, shipY + 15, shipY + 15},
            3
        );
    }

    public static void main(String[] args) { launch(args); }
}
```

