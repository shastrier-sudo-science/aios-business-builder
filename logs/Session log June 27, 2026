function goPro() {
  // If a real LemonSqueezy checkout URL is configured, send the user straight there.
  if (CONFIG.PRO_PAYMENT_URL && CONFIG.PRO_PAYMENT_URL.trim() !== '') {
    window.open(CONFIG.PRO_PAYMENT_URL, '_blank');
    return;
  }

  // Fallback: PRO_PAYMENT_URL not set yet — scroll to the waitlist form instead
  const form = document.getElementById('upgrade-intent-form');
  if (form) {
    form.scrollIntoView({ behavior: 'smooth', block: 'center' });
    setTimeout(() => {
      const inp = document.getElementById('pro-intent-email');
      if (inp) inp.focus();
    }, 400);
  } else {
    switchTab('about');
    showToast('Pro launch coming soon. Leave your email in the forecast results to be first notified.');
  }
}
```

**Why:** Current `goPro()` always scrolls to the waitlist form and never opens a payment link, even after `PRO_PAYMENT_URL` is filled in. This patch makes the button live the moment LemonSqueezy approves — zero further code changes needed.

